# Placeholder environment file.
# Do not add real credentials during the scaffold phase.

# CLIENT_APP_URL=http://localhost:5173
# SERVER_PORT=3000
# DATABASE_URL=postgresql://placeholder-user:placeholder-password@localhost:5432/flim

# Server-side TMDb credentials for /api/movies search/detail cache proxy.
# Preferred: TMDb v4 read access token.
# TMDB_ACCESS_TOKEN=

# Fallback: TMDb v3 API key.
# TMDB_API_KEY=

# Server-side OpenAI key used by the trivia generation API.
# OPENAI_API_KEY=
# Optional model override. Defaults to gpt-4.1-mini in the API route.
# OPENAI_TRIVIA_MODEL=

# Private Director editorial admin. These are server-side only.
# DIRECTOR_ADMIN_USERNAME=
# DIRECTOR_ADMIN_PASSWORD=

# Optional server-side streaming availability source for Where To Watch V1.
# If omitted, Flim shows an honest "Streaming availability coming soon" state.
# WATCHMODE_API_KEY=

# Web Push / PWA release alerts. Generate with:
# npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:hello@flim.ca

# Public app URL used in push notification click targets.
# PUBLIC_APP_URL=https://www.flim.ca

# Native playlist ads are disabled by default. Do not enable until ad review,
# placement rules, reporting, and labeling are production-ready.
ENABLE_NATIVE_ADS=false

# Trivia, games, and challenge surfaces are disabled by default.
# Server flag protects future challenge APIs; Vite flag controls client navigation.
ENABLE_TRIVIA_GAMES=false
VITE_ENABLE_TRIVIA_GAMES=false
