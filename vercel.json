{
  "buildCommand": "npm run build",
  "outputDirectory": "client/dist",
  "crons": [
    {
      "path": "/api/cron/release-check",
      "schedule": "0 11 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/api/admin/export",
      "destination": "/api/profiles/admin-export"
    },
    {
      "source": "/p/:slug*",
      "destination": "/api/public-page/:slug*"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
