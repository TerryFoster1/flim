{
  "buildCommand": "npm run build",
  "outputDirectory": "client/dist",
  "functions": {
    "api/og/*.ts": {
      "includeFiles": "{node_modules/{sharp,@img}/**/*,api/assets/**/*}"
    },
    "api/og/**/*.ts": {
      "includeFiles": "{node_modules/{sharp,@img}/**/*,api/assets/**/*}"
    }
  },
  "crons": [
    {
      "path": "/api/cron/release-check",
      "schedule": "0 11 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/api/admin/export",
      "destination": "/api/profiles/admin-export"
    },
    {
      "source": "/p/:slug*",
      "destination": "/api/public-page/:slug*"
    },
    {
      "source": "/@:handle",
      "destination": "/api/profile-page/:handle"
    },
    {
      "source": "/movies/:tmdbId",
      "destination": "/api/title-page/movie/:tmdbId"
    },
    {
      "source": "/tv/:tmdbId",
      "destination": "/api/title-page/tv/:tmdbId"
    },
    {
      "source": "/games/title/:mediaType/:tmdbId",
      "destination": "/api/games-title-page/:mediaType/:tmdbId"
    },
    {
      "source": "/collection/:slug",
      "destination": "/api/collection-page/:slug"
    },
    {
      "source": "/((?!api/|assets/|provider-icons/|avatars/|brand/|favicon.ico|favicon.png|manifest.json|sw.js).*)",
      "destination": "/index.html"
    }
  ]
}
